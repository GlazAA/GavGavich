@page "/prilozhenie"
@page "/app"
@layout MainLayout

<PageTitle>Приложение — ГавГавыч</PageTitle>

<section class="info-page">
    <div class="container">
        <p class="back-link"><a href="/">← На главную</a></p>
        <p class="info-page__eyebrow">Бонус для клиентов школы</p>
        <h1 class="info-page__title">Приложение ГавГавыч</h1>
        <p class="info-page__lead info-page__lead--wide">
            Когда присоединяетесь к школе, приложение открывается бесплатно.
            Это не замена занятий, а ваш карманный помощник между встречами с кинологом.
        </p>

        <div class="app-hero">
            <div class="app-hero__copy">
                <h2>Что внутри</h2>
                <p>
                    Фиксируете поведение, смотрите учебные видео с комментариями к уроку, пишете кинологу,
                    не забываете про прививки и «что взять с собой». Кинолог видит динамику — занятие проходит предметнее.
                </p>
                <a class="btn btn--primary" href="/booking" data-enhance-nav="false">Присоединиться и получить доступ</a>
            </div>
            <div class="app-hero__art">
                <span class="img-placeholder" aria-label="Главный экран приложения"></span>
            </div>
        </div>

        <div class="app-shots">
            <h2 class="app-shots__title">Как выглядит приложение</h2>
            <p class="app-shots__lead">Примеры экранов — пока заглушки. На телефоне листайте вбок.</p>
            <div class="app-shots__scroller" tabindex="0" aria-label="Примеры экранов приложения">
                @foreach (var shot in Shots)
                {
                    <figure class="app-shot">
                        <span class="img-placeholder app-shot__frame" aria-hidden="true"></span>
                        <figcaption>@shot</figcaption>
                    </figure>
                }
            </div>
        </div>

        <div class="app-features">
            @foreach (var feature in Features)
            {
                <article class="app-feature">
                    <div class="app-feature__icon" aria-hidden="true">@feature.Icon</div>
                    <h3>@feature.Title</h3>
                    <p>@feature.Text</p>
                </article>
            }
        </div>

        <aside class="app-message" aria-label="Сообщение от Анастасии">
            <div class="app-message__bubble">
                <p class="app-message__from">Анастасия, основатель школы</p>
                <p>
                    Приложение нужно не только владельцам. Оно важно и для специалистов —
                    для вашего роста и аккуратной работы с каждой парой «человек + собака».
                </p>
                <p>
                    Мы за системность, бережность и последовательность: чтобы прогресс не держался
                    на удачном дне, а складывался из понятных шагов между занятиями.
                    Когда дневник, домашки и уроки в одном месте — проще видеть правду о динамике
                    и не торопить собаку там, где ей нужно время.
                </p>
                <p class="app-message__sign">С уважением, Анастасия</p>
            </div>
        </aside>

        <div class="app-note">
            <h2>Для кого это особенно полезно</h2>
            <ul>
                <li>если между занятиями сложно «не сбиться» с режима;</li>
                <li>если нужно показать кинологу, <em>когда именно</em> начинается лай или вспышка;</li>
                <li>если хотите повторять куски урока дома в удобном темпе;</li>
                <li>если вы специалист школы и хотите вести клиентов системно, без хаоса в заметках.</li>
            </ul>
            <p>
                Доступ открывается после старта работы со школой. Ссылки на iOS/Android появятся в личном кабинете.
            </p>
        </div>
    </div>
</section>

@code {
    private sealed record Feature(string Icon, string Title, string Text);

    private static readonly string[] Shots =
    [
        "Главный экран",
        "Дневник лая и здоровье",
        "Урок: видео и комментарии",
        "Чат с кинологом",
        "Календарь прививок",
        "Что взять на занятие"
    ];

    private static readonly Feature[] Features =
    [
        new("📒", "Дневник лая и контроль здоровья",
            "Отмечаете эпизоды лая, аппетит, стул, активность — видно, что меняется от недели к неделе."),
        new("⚡️", "Быстрая запись к специалисту",
            "Пара касаний — и заявка на занятие или уточнение слота у вашего кинолога."),
        new("▶️", "Учебные видео и комментарии к уроку",
            "Не «было → стало», а разбор занятия: что уже прошли и что будем проходить дальше — с короткими видео и пояснениями."),
        new("💬", "Чат и вопросы кинологу",
            "Между занятиями можно уточнить домашку, описать вспышку или спросить, как лучше поступить в быту."),
        new("📅", "Календарь прививок и обработок",
            "Даты вакцинации, обработок от паразитов и напоминания — чтобы важное не терялось в переписке."),
        new("🎒", "Что взять с собой на первое занятие",
            "Напоминания про снаряжение: намордник, длинный поводок, лакомства и всё, что нужно именно вам."),
        new("✅", "Домашние задания и чек-листы",
            "Что потренировать до следующей встречи: галочки, прогресс по командам, короткие напоминания."),
        new("🩺", "Когда к ветеринару, а не к кинологу",
            "Памятка: какие симптомы и ситуации — зона ветврача. Поведение учим мы, здоровье — клиника.")
    ];
}
